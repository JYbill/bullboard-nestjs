[
  {
    // Redis 主机地址
    "host": "127.0.0.1",
    // Redis 端口
    "port": 6379,
    // Redis 密码，没有可以留空字符串
    "password": "<redis-password>",
    // Redis DB 库号
    "dbNum": 0,
    // BullMQ 的 prefix，必填
    "bullPrefix": "bull",
    // Bull Board 展示前缀，可省略
    "prefix": "app-",
    // 要展示的队列名列表
    "queues": ["example-queue"]
  }
]
