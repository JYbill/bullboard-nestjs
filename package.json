{
  "name": "rag-server",
  "version": "0.0.1",
  "private": true,
  "description": "bull board 管理面板",
  "license": "UNLICENSED",
  "author": "",
  "type": "module",
  "scripts": {
    "skills:update": "skills add https://github.com/JYbill/xqv-skills --copy -a universal claude-code -y -s ddt -s notes -s summary -s upgrade-project -s test-optimize",
    "prepare": "husky",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node --enable-source-maps dist/main.js",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "oxlint --config oxlint.config.ts src test --fix",
    "test": "vitest run --project test --passWithNoTests",
    "test:watch": "vitest --project test",
    "test:cov": "vitest run --coverage --project test --passWithNoTests",
    "test:debug": "vitest --inspectBrk --project test --testTimeout 0 --hookTimeout 0",
    "test:e2e": "vitest run --project e2e --passWithNoTests",
    "deploy:docker": "bash ./docker-build.sh -p x86-debian",
    "deploy:docker:local": "bash ./docker-build.sh -p x86-debian -s"
  },
  "dependencies": {
    "@bull-board/api": "^8.0.0",
    "@bull-board/express": "^8.0.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.27",
    "@swc/helpers": "^0.5.23",
    "bullmq": "^5.78.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.41",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/ms": "^2.1.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv-cli": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "skills": "^1.5.11",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3",
    "unplugin-swc": "^1.5.9",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
